@model ChangeRequestDetailsVM

@{
    ViewData["Title"] = "Detalle de cambio";
}

@await Html.PartialAsync("_HeaderTitle", new HeaderTitle { Title = "Solicitud de cambio", Subtitle = "Detalle e historial de auditoria" })

<div class="mt-5 rounded-lg bg-white p-5 shadow">
    <div class="grid grid-cols-2 gap-4">
        <div>
            <p class="text-sm text-gray-500">Codigo</p>
            <p class="font-medium text-gray-900">@Model.Code</p>
        </div>
        <div>
            <p class="text-sm text-gray-500">Clasificacion</p>
            <p class="font-medium text-gray-900">@Model.Clasification</p>
        </div>
        <div>
            <p class="text-sm text-gray-500">Prioridad</p>
            <p class="font-medium text-gray-900">@Model.Priority</p>
        </div>
        <div>
            <p class="text-sm text-gray-500">Proceso</p>
            <p class="font-medium text-gray-900">@Model.Status</p>
        </div>
        <div>
            <p class="text-sm text-gray-500">Estado</p>
            <p class="font-medium text-gray-900">@Model.Action</p>
        </div>
        <div>
            <p class="text-sm text-gray-500">Aprobacion formal</p>
            <p class="font-medium text-gray-900">@Model.ApprovalStatus</p>
        </div>
        <div>
            <p class="text-sm text-gray-500">Responsable</p>
            <p class="font-medium text-gray-900">@(Model.ApprovalAssigneeUserId ?? "-")</p>
        </div>
        <div>
            <p class="text-sm text-gray-500">Solicitada</p>
            <p class="font-medium text-gray-900">@(Model.ApprovalRequestedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") ?? "-")</p>
        </div>
        <div>
            <p class="text-sm text-gray-500">SLA limite</p>
            <p class="font-medium text-gray-900">@(Model.ApprovalDueAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") ?? "-")</p>
        </div>
        <div>
            <p class="text-sm text-gray-500">Decision tomada</p>
            <p class="font-medium text-gray-900">@(Model.ApprovalDecidedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss") ?? "-")</p>
        </div>
        @if (Model.IsSlaExpired)
        {
            <div class="col-span-2">
                <p class="rounded bg-red-100 px-3 py-2 text-sm text-red-700">
                    La solicitud de aprobacion esta fuera de SLA.
                </p>
            </div>
        }
        <div class="col-span-2">
            <p class="text-sm text-gray-500">Descripcion</p>
            <p class="font-medium text-gray-900">@Model.Description</p>
        </div>
    </div>
</div>

<div class="mt-6 rounded-lg bg-white p-5 shadow">
    <h2 class="text-lg font-semibold text-gray-900">Workflow de aprobacion</h2>
    <form asp-action="RequestApproval" method="post" class="mt-4 flex flex-wrap items-end gap-3">
        <input type="hidden" name="id" value="@Model.Id" />
        <div>
            <label class="mb-2 block text-sm font-medium text-gray-900">Responsable (UserId)</label>
            <input name="approverUserId" type="text" value="@Model.ApprovalAssigneeUserId"
                   class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
        </div>
        <div>
            <label class="mb-2 block text-sm font-medium text-gray-900">SLA (horas)</label>
            <input name="slaHours" type="number" min="1" max="720" value="48"
                   class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
        </div>
        <button type="submit"
                class="inline-flex w-full flex-shrink-0 items-center justify-center rounded-lg px-5 py-2.5 text-sm font-semibold shadow-sm transition focus:outline-none focus:ring-2 focus:ring-indigo-400 sm:w-auto"
                style="background-color:#4338ca;color:#ffffff;border:1px solid #3730a3;">
            Solicitar aprobacion
        </button>
    </form>

    @if (Model.IsPendingApproval && Model.IsCurrentUserApprover)
    {
        <div class="mt-4 flex gap-2">
            <form asp-action="Approve" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="rounded-lg bg-green-700 px-4 py-2 text-sm font-medium text-white hover:bg-green-800">
                    Aprobar
                </button>
            </form>
            <form asp-action="Reject" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <button type="submit" class="rounded-lg bg-red-700 px-4 py-2 text-sm font-medium text-white hover:bg-red-800">
                    Rechazar
                </button>
            </form>
        </div>
    }
</div>

<div class="mt-6 rounded-lg bg-white p-5 shadow">
    <h2 class="text-lg font-semibold text-gray-900">Trazabilidad Version/Baseline</h2>
    @if (!Model.Versions.Any())
    {
        <p class="mt-3 text-sm text-gray-500">No hay versiones asociadas a esta CR.</p>
    }
    else
    {
        <div class="mt-4 overflow-x-auto">
            <table class="min-w-full border-collapse">
                <thead>
                    <tr class="border-b border-gray-200 bg-gray-100">
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Version</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Estado</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Fase</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Iteracion</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var version in Model.Versions)
                    {
                        <tr class="border-b border-gray-100">
                            <td class="px-4 py-2 text-sm text-gray-800">@version.VersionCode (@version.VersionId)</td>
                            <td class="px-4 py-2 text-sm text-gray-800">@version.State</td>
                            <td class="px-4 py-2 text-sm text-gray-800">@version.Phase</td>
                            <td class="px-4 py-2 text-sm text-gray-800">@version.Iteration</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="mt-6 rounded-lg bg-white p-5 shadow">
    <h2 class="text-lg font-semibold text-gray-900">Trazabilidad Git (Commit/PR)</h2>
    @if (TempData["Message"] is string message && !string.IsNullOrWhiteSpace(message))
    {
        var messageType = (TempData["MessageType"]?.ToString() ?? "info").ToLowerInvariant();
        var messageClasses = messageType switch
        {
            "success" => "bg-green-100 text-green-800",
            "warning" => "bg-amber-100 text-amber-800",
            "error" => "bg-red-100 text-red-800",
            _ => "bg-blue-100 text-blue-800"
        };

        <p class="mt-2 rounded px-3 py-2 text-sm @messageClasses">
            @message
        </p>
    }
    <p class="mt-2 rounded bg-blue-50 px-3 py-2 text-xs text-blue-800">
        Regla para baselinar: se requiere al menos un commit verificable en GitHub o un PR en estado merged.
    </p>
    <div class="mt-3 flex flex-wrap gap-3">
        <a asp-action="TraceabilityReport" asp-route-id="@Model.Id" target="_blank"
           class="inline-flex min-h-10 items-center justify-center rounded-lg px-4 py-2 text-sm font-semibold text-white"
           style="background-color:#334155;color:#ffffff;border:1px solid #1e293b;">
            Ver reporte JSON
        </a>
        <a asp-action="ExportTraceabilityCsv" asp-route-id="@Model.Id"
           class="inline-flex min-h-10 items-center justify-center rounded-lg px-4 py-2 text-sm font-semibold text-white"
           style="background-color:#047857;color:#ffffff;border:1px solid #065f46;">
            Exportar trazabilidad CSV
        </a>
        <a asp-action="ExportTraceabilityExcel" asp-route-id="@Model.Id"
           class="inline-flex min-h-10 items-center justify-center rounded-lg px-4 py-2 text-sm font-semibold text-white"
           style="background-color:#15803d;color:#ffffff;border:1px solid #166534;">
            Exportar Excel
        </a>
        <a asp-action="ExportTraceabilityPdf" asp-route-id="@Model.Id"
           class="inline-flex min-h-10 items-center justify-center rounded-lg px-4 py-2 text-sm font-semibold text-white"
           style="background-color:#b91c1c;color:#ffffff;border:1px solid #991b1b;">
            Exportar PDF
        </a>
    </div>
    <form asp-action="AddGitTrace" method="post" class="mt-4 grid grid-cols-1 gap-3 md:grid-cols-6">
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="md:col-span-2">
            <label class="mb-2 block text-sm font-medium text-gray-900">Repositorio (owner/repo o URL GitHub)</label>
            <input name="repository" type="text" placeholder="org/repo o https://github.com/org/repo"
                   class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
        </div>
        <div>
            <label class="mb-2 block text-sm font-medium text-gray-900">Commit SHA</label>
            <input name="commitSha" type="text" placeholder="abc123..."
                   class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
        </div>
        <div>
            <label class="mb-2 block text-sm font-medium text-gray-900">PR Number</label>
            <input name="pullRequestNumber" type="number" min="1"
                   class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
        </div>
        <div>
            <label class="mb-2 block text-sm font-medium text-gray-900">Version ID</label>
            <input name="versionId" type="number" min="1"
                   class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
        </div>
        <div>
            <label class="mb-2 block text-sm font-medium text-gray-900">PR URL</label>
            <input name="pullRequestUrl" type="url" placeholder="https://github.com/..."
                   class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
        </div>
        <div class="md:col-span-6">
            <button type="submit" class="rounded-lg bg-gray-800 px-4 py-2 text-sm font-medium text-white hover:bg-gray-900">
                Vincular trazabilidad
            </button>
        </div>
    </form>

    @if (!Model.GitTraceLinks.Any())
    {
        <p class="mt-3 text-sm text-gray-500">No hay commits/PR vinculados.</p>
    }
    else
    {
        <div class="mt-4 overflow-x-auto">
            <table class="min-w-full border-collapse">
                <thead>
                    <tr class="border-b border-gray-200 bg-gray-100">
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Fecha</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Repositorio</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Commit</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">PR</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Version</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Accion</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var trace in Model.GitTraceLinks)
                    {
                        <tr class="border-b border-gray-100">
                            <td class="px-4 py-2 text-sm text-gray-800">@trace.LinkedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                            <td class="px-4 py-2 text-sm text-gray-800">@trace.Repository</td>
                            <td class="px-4 py-2 text-sm text-gray-800">@trace.CommitSha</td>
                            <td class="px-4 py-2 text-sm text-gray-800">
                                @if (!string.IsNullOrWhiteSpace(trace.PullRequestUrl))
                                {
                                    <a href="@trace.PullRequestUrl" target="_blank" class="text-blue-700 underline">
                                        #@trace.PullRequestNumber
                                    </a>
                                }
                                else
                                {
                                    @($"#{trace.PullRequestNumber}")
                                }
                            </td>
                            <td class="px-4 py-2 text-sm text-gray-800">@trace.VersionId</td>
                            <td class="px-4 py-2 text-sm text-gray-800">
                                <form asp-action="UpdateGitTrace" method="post" class="mb-2 grid grid-cols-1 gap-1">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <input type="hidden" name="traceId" value="@trace.Id" />
                                    <input name="repository" type="text" value="@trace.Repository" class="rounded border border-gray-300 px-2 py-1 text-xs" />
                                    <input name="commitSha" type="text" value="@trace.CommitSha" class="rounded border border-gray-300 px-2 py-1 text-xs" />
                                    <input name="pullRequestNumber" type="number" min="1" value="@trace.PullRequestNumber" class="rounded border border-gray-300 px-2 py-1 text-xs" />
                                    <input name="versionId" type="number" min="1" value="@trace.VersionId" class="rounded border border-gray-300 px-2 py-1 text-xs" />
                                    <input name="pullRequestUrl" type="url" value="@trace.PullRequestUrl" class="rounded border border-gray-300 px-2 py-1 text-xs" />
                                    <button type="submit" class="rounded bg-amber-600 px-3 py-1 text-xs text-white hover:bg-amber-700">
                                        Actualizar
                                    </button>
                                </form>
                                <form asp-action="RemoveGitTrace" method="post">
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <input type="hidden" name="traceId" value="@trace.Id" />
                                    <button type="submit" class="rounded bg-red-700 px-3 py-1 text-xs text-white hover:bg-red-800">
                                        Eliminar
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="mt-6 rounded-lg bg-white p-5 shadow">
    <h2 class="text-lg font-semibold text-gray-900">Historial de estados</h2>
    @if (!Model.StateHistory.Any())
    {
        <p class="mt-3 text-sm text-gray-500">No hay transiciones de estado registradas.</p>
    }
    else
    {
        <div class="mt-4 overflow-x-auto">
            <table class="min-w-full border-collapse">
                <thead>
                    <tr class="border-b border-gray-200 bg-gray-100">
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Fecha</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Usuario</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Transicion</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.StateHistory)
                    {
                        <tr class="border-b border-gray-100">
                            <td class="px-4 py-2 text-sm text-gray-800">@item.ChangedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                            <td class="px-4 py-2 text-sm text-gray-800">@item.ChangedByUserId</td>
                            <td class="px-4 py-2 text-sm text-gray-800">@item.Summary</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="mt-6 rounded-lg bg-white p-5 shadow">
    <h2 class="text-lg font-semibold text-gray-900">Historial</h2>
    @if (!Model.Audits.Any())
    {
        <p class="mt-3 text-sm text-gray-500">No hay eventos de auditoria registrados.</p>
    }
    else
    {
        <div class="mt-4 overflow-x-auto">
            <table class="min-w-full border-collapse">
                <thead>
                    <tr class="border-b border-gray-200 bg-gray-100">
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Fecha</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Usuario</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Evento</th>
                        <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Detalle</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var audit in Model.Audits)
                    {
                        <tr class="border-b border-gray-100">
                            <td class="px-4 py-2 text-sm text-gray-800">@audit.ChangedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                            <td class="px-4 py-2 text-sm text-gray-800">@audit.ChangedByUserId</td>
                            <td class="px-4 py-2 text-sm text-gray-800">@audit.EventType</td>
                            <td class="px-4 py-2 text-sm text-gray-800">@audit.Summary</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<div class="mt-5">
    <a asp-action="Index" class="rounded-lg bg-blue-700 px-5 py-2 text-sm font-medium text-white hover:bg-blue-800">
        Volver
    </a>
</div>

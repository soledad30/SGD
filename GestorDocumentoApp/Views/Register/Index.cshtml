@{
    ViewData["Title"] = "Register Page";
}

@await Html.PartialAsync("_HeaderTitle", new HeaderTitle { Title = "Registros", Subtitle = "Datos auxiliares" })

<div>

    <ul class="grid grid-cols-1 gap-6 md:grid-cols-4">
        <li>
            <a asp-controller="ElementType" asp-action="Index">
                <div class="flex items-center space-x-4 rounded-lg bg-white p-4 shadow">
                    <img class="h-16 w-16 rounded-full object-cover"
                         src="https://cdn-icons-png.flaticon.com/512/16539/16539061.png"
                         alt="Módulo Registro">
                    <div>
                        <h2 class="text-md font-semibold text-gray-900">Tipo de elemento</h2>
                        <p class="text-sm text-gray-600">Gestión de tipo de elementos.</p>
                    </div>
                </div>
            </a>


        </li>
        <li>
            <a asp-controller="RequirementType" asp-action="Index">
                <div class="flex items-center space-x-4 rounded-lg bg-white p-4 shadow">
                    <img class="h-16 w-16 rounded-full object-cover"
                         src="https://cdn-icons-png.flaticon.com/512/12530/12530966.png"
                         alt="Módulo CI">
                    <div>
                        <h2 class="text-md font-semibold text-gray-900">Tipo de requerimiento</h2>
                        <p class="text-sm text-gray-600">Gestion de tipo de requerimiento.</p>
                    </div>

                </div>
            </a>
        </li>
        <li>
            <a asp-controller="Register" asp-action="Users">
                <div class="flex items-center space-x-4 rounded-lg bg-white p-4 shadow">
                    <img class="h-16 w-16 rounded-full object-cover"
                         src="https://cdn-icons-png.flaticon.com/512/10988/10988120.png"
                         alt="Usuarios y roles">
                    <div>
                        <h2 class="text-md font-semibold text-gray-900">Usuarios y roles</h2>
                        <p class="text-sm text-gray-600">Alta de usuarios y asignacion de rol.</p>
                    </div>
                </div>
            </a>
        </li>

    </ul>

</div>


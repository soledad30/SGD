@model UserAdminVM

@{
    ViewData["Title"] = "Usuarios y roles";
}

@await Html.PartialAsync("_HeaderTitle", new HeaderTitle { Title = "Usuarios y roles", Subtitle = "Gestion administrativa de cuentas" })

<div class="mt-5 rounded-lg bg-white p-5 shadow">
    <h2 class="text-lg font-semibold text-gray-900">Crear usuario</h2>
    <form asp-action="CreateUser" method="post" class="mt-4 grid grid-cols-1 gap-4 md:grid-cols-4">
        <div>
            <label class="mb-2 block text-sm font-medium text-gray-900">Email</label>
            <input name="Email" type="email" required
                   class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
        </div>
        <div>
            <label class="mb-2 block text-sm font-medium text-gray-900">Password</label>
            <input name="Password" type="password" required minlength="8"
                   class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
        </div>
        <div>
            <label class="mb-2 block text-sm font-medium text-gray-900">Rol</label>
            <select name="Role" class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600">
                @foreach (var role in Model.AvailableRoles)
                {
                    <option value="@role">@role</option>
                }
            </select>
        </div>
        <div class="flex items-end">
            <button type="submit"
                    class="inline-flex min-h-10 items-center justify-center rounded-lg px-5 py-2 text-sm font-semibold text-white"
                    style="background-color:#1d4ed8;color:#ffffff;border:1px solid #1e40af;">
                Crear
            </button>
        </div>
    </form>
</div>

<div class="mt-6 rounded-lg bg-white p-5 shadow">
    <h2 class="text-lg font-semibold text-gray-900">Usuarios registrados</h2>
    <div class="mt-4 overflow-x-auto">
        <table class="min-w-full border-collapse">
            <thead>
                <tr class="border-b border-gray-200 bg-gray-100">
                    <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Email</th>
                    <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Rol actual</th>
                    <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Cambiar rol</th>
                    <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr class="border-b border-gray-100">
                        <td class="px-4 py-2 text-sm text-gray-800">@user.Email</td>
                        <td class="px-4 py-2 text-sm text-gray-800">@string.Join(", ", user.Roles)</td>
                        <td class="px-4 py-2 text-sm text-gray-800">
                            <form asp-action="AssignRole" method="post" class="flex items-center gap-2">
                                <input type="hidden" name="UserId" value="@user.UserId" />
                                <select name="Role" class="rounded-lg border border-gray-300 bg-gray-50 p-2 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600">
                                    @foreach (var role in Model.AvailableRoles)
                                    {
                                        <option value="@role">@role</option>
                                    }
                                </select>
                                <button type="submit"
                                        class="inline-flex min-h-9 items-center justify-center rounded-lg px-3 py-2 text-xs font-semibold text-white"
                                        style="background-color:#4338ca;color:#ffffff;border:1px solid #3730a3;">
                                    Guardar
                                </button>
                            </form>
                        </td>
                        <td class="px-4 py-2 text-sm text-gray-800">
                            <button type="button"
                                    class="open-reset-modal inline-flex min-h-9 items-center justify-center rounded-lg px-3 py-2 text-xs font-semibold text-white"
                                    style="background-color:#dc2626;color:#ffffff;border:1px solid #b91c1c;"
                                    data-user-id="@user.UserId"
                                    data-user-email="@user.Email"
                                    data-is-admin="@(user.Roles.Any(r => string.Equals(r, "Admin", StringComparison.OrdinalIgnoreCase)).ToString().ToLowerInvariant())">
                                Restablecer contraseña
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="reset-password-modal"
     class="p-4"
     style="display:none;position:fixed;inset:0;z-index:9999;align-items:center;justify-content:center;background:rgba(0,0,0,0.45);">
    <div class="w-full max-w-md rounded-xl bg-white p-6 shadow-2xl" style="max-height:90vh;overflow-y:auto;border:1px solid #e5e7eb;">
        <div class="mb-5 flex items-start justify-between gap-3 border-b border-gray-200 pb-3">
            <div>
                <h3 class="text-base font-semibold text-gray-900">Restablecer contraseña</h3>
                <p id="reset-user-label" class="mt-1 text-sm text-gray-600"></p>
            </div>
            <button id="close-reset-modal" type="button" class="rounded border border-gray-300 px-2 py-1 text-xs text-gray-700 hover:bg-gray-100">
                Cerrar
            </button>
        </div>

        <form asp-action="ResetPassword" method="post" class="space-y-4">
            <input id="reset-user-id" type="hidden" name="UserId" />
            <div>
                <label class="mb-2 block text-sm font-medium text-gray-900">Nueva contraseña</label>
                <input id="reset-new-password" name="NewPassword" type="password" required minlength="8"
                       class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
            </div>
            <div>
                <label class="mb-2 block text-sm font-medium text-gray-900">Confirmar contraseña</label>
                <input id="reset-confirm-password" name="ConfirmPassword" type="password" required minlength="8"
                       class="block w-full rounded-lg border border-gray-300 bg-gray-50 p-2.5 text-sm text-gray-900 focus:border-blue-600 focus:ring-blue-600" />
            </div>
            <div class="flex items-center gap-2 pt-1">
                <button id="toggle-reset-passwords" type="button"
                        class="inline-flex min-h-9 items-center justify-center rounded-lg px-3 py-2 text-xs font-semibold text-white"
                        style="background-color:#6b7280;color:#ffffff;border:1px solid #4b5563;">
                    Mostrar
                </button>
                <label class="inline-flex items-center gap-2 text-xs text-gray-700">
                    <input id="confirm-admin-reset" type="checkbox" name="ConfirmAdminReset" value="true" class="h-4 w-4 rounded border-gray-300 text-red-600 focus:ring-red-500" />
                    Confirmo reset de admin
                </label>
            </div>
            <p id="admin-warning" class="hidden rounded bg-amber-50 px-3 py-2 text-xs text-amber-700">
                Este usuario es admin. Debes marcar la confirmación de seguridad.
            </p>
            <div class="flex justify-end gap-2 pt-2">
                <button id="cancel-reset-modal" type="button" class="inline-flex min-h-9 items-center justify-center rounded-lg px-3 py-2 text-xs font-semibold text-gray-700 border border-gray-300">
                    Cancelar
                </button>
                <button type="submit"
                        class="inline-flex min-h-9 items-center justify-center rounded-lg px-3 py-2 text-xs font-semibold text-white"
                        style="background-color:#dc2626;color:#ffffff;border:1px solid #b91c1c;">
                    Restablecer contraseña
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    var modal = document.getElementById('reset-password-modal');
    var openButtons = document.querySelectorAll('.open-reset-modal');
    var closeButton = document.getElementById('close-reset-modal');
    var cancelButton = document.getElementById('cancel-reset-modal');
    var userIdInput = document.getElementById('reset-user-id');
    var userLabel = document.getElementById('reset-user-label');
    var newPasswordInput = document.getElementById('reset-new-password');
    var confirmPasswordInput = document.getElementById('reset-confirm-password');
    var toggleButton = document.getElementById('toggle-reset-passwords');
    var confirmAdminCheckbox = document.getElementById('confirm-admin-reset');
    var adminWarning = document.getElementById('admin-warning');

    function closeModal() {
        modal.style.display = 'none';
        userIdInput.value = '';
        userLabel.textContent = '';
        newPasswordInput.value = '';
        confirmPasswordInput.value = '';
        confirmAdminCheckbox.checked = false;
        adminWarning.classList.add('hidden');
        newPasswordInput.type = 'password';
        confirmPasswordInput.type = 'password';
        toggleButton.textContent = 'Mostrar';
    }

    openButtons.forEach(function (button) {
        button.addEventListener('click', function () {
            var userId = button.getAttribute('data-user-id') || '';
            var userEmail = button.getAttribute('data-user-email') || '';
            var isAdmin = button.getAttribute('data-is-admin') === 'true';

            userIdInput.value = userId;
            userLabel.textContent = 'Usuario: ' + userEmail;
            adminWarning.classList.toggle('hidden', !isAdmin);
            if (!isAdmin) {
                confirmAdminCheckbox.checked = false;
            }

            modal.style.display = 'flex';
            newPasswordInput.focus();
        });
    });

    [closeButton, cancelButton].forEach(function (button) {
        button.addEventListener('click', closeModal);
    });

    modal.addEventListener('click', function (event) {
        if (event.target === modal) {
            closeModal();
        }
    });

    toggleButton.addEventListener('click', function () {
        var shouldShow = toggleButton.textContent.trim() === 'Mostrar';
        newPasswordInput.type = shouldShow ? 'text' : 'password';
        confirmPasswordInput.type = shouldShow ? 'text' : 'password';
        toggleButton.textContent = shouldShow ? 'Ocultar' : 'Mostrar';
    });
</script>

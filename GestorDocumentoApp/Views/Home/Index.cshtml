@{
    ViewData["Title"] = "Project Page";
}


@await Html.PartialAsync("_HeaderTitle", new HeaderTitle { Title = "Modulos", Subtitle = "Listado de modulos disponibles" })



<div>

    <ul class="grid grid-cols-1 gap-6 md:grid-cols-4">
        <li>
            <a asp-controller="Register" asp-action="Index">
                <div class="flex items-center space-x-4 rounded-lg bg-white p-4 shadow">
                    <span class="icon-badge" aria-hidden="true"><i class="fi fi-rr-user-add"></i></span>
                    <div>
                        <h2 class="font-semibold text-gray-900">Registro</h2>
                        <p class="text-sm text-gray-600">Gestión de registros para los modulos.</p>
                    </div>
                </div>
            </a>


        </li>
        <li>
            <a asp-controller="Element" asp-action="Index">
                <div class="flex items-center space-x-4 rounded-lg bg-white p-4 shadow">
                    <span class="icon-badge" aria-hidden="true"><i class="fi fi-rr-cube"></i></span>
                    <div>
                        <h2 class="font-semibold text-gray-900">Elementos CI</h2>
                        <p class="text-sm text-gray-600">Control de configuraciones e infraestructura.</p>
                    </div>

                </div>
            </a>
        </li>

        <li>
            <a asp-controller="ChangeRequest" asp-action="Index">
                <div class="flex items-center space-x-4 rounded-lg bg-white p-4 shadow">
                    <span class="icon-badge" aria-hidden="true"><i class="fi fi-rr-refresh"></i></span>
                    <div>
                        <h2 class="font-semibold text-gray-900">Cambios</h2>
                        <p class="text-sm text-gray-600">Cambios solicitados.</p>
                    </div>
                </div>

            </a>
        </li>

        <li>
            <a asp-controller="Project" asp-action="Index">
                <div class="flex items-center space-x-4 rounded-lg bg-white p-4 shadow">
                    <span class="icon-badge" aria-hidden="true"><i class="fi fi-rr-briefcase"></i></span>
                    <div>
                        <h2 class="font-semibold text-gray-900">Proyectos</h2>
                        <p class="text-sm text-gray-600">Organización y seguimiento de tareas y proyectos.</p>
                    </div>
                </div>

            </a>
        </li>

        <li>
            <a asp-controller="Project" asp-action="Index">
                <div class="flex items-center space-x-4 rounded-lg bg-white p-4 shadow">
                    <span class="icon-badge" aria-hidden="true"><i class="fi fi-rr-search-alt"></i></span>
                    <div>
                        <h2 class="font-semibold text-gray-900">Test</h2>
                        <p class="text-sm text-gray-600">GitFlows automation.</p>
                    </div>
                </div>

            </a>
        </li>


    </ul>

</div>

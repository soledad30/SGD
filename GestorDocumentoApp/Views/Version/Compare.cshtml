@model VersionCompareVM

@{
    ViewData["Title"] = "Comparar versiones";
}

@await Html.PartialAsync("_HeaderTitle", new HeaderTitle { Title = "Comparar versiones", Subtitle = $"Elemento: {Model.ElementName}" })

<div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2">
    <div class="rounded-lg bg-white p-5 shadow">
        <h2 class="text-lg font-semibold text-gray-900">Origen: @Model.Source.VersionCode</h2>
        <ul class="mt-3 space-y-1 text-sm text-gray-700">
            <li><strong>ID:</strong> @Model.Source.Id</li>
            <li><strong>Nombre:</strong> @Model.Source.Name</li>
            <li><strong>Estado:</strong> @Model.Source.State</li>
            <li><strong>Fase:</strong> @PhaseHelper.GetPhaseName(Model.Source.Phase)</li>
            <li><strong>Iteracion:</strong> @Model.Source.Iteration</li>
            <li><strong>Tipo req.:</strong> @Model.Source.RequirementTypeName</li>
            <li><strong>CR:</strong> @Model.Source.ChangeRequestCode</li>
            <li><strong>Subida:</strong> @Model.Source.UploadDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</li>
            <li><strong>Version padre:</strong> @(Model.Source.ParentVersionId?.ToString() ?? "-")</li>
        </ul>
    </div>
    <div class="rounded-lg bg-white p-5 shadow">
        <h2 class="text-lg font-semibold text-gray-900">Destino: @Model.Target.VersionCode</h2>
        <ul class="mt-3 space-y-1 text-sm text-gray-700">
            <li><strong>ID:</strong> @Model.Target.Id</li>
            <li><strong>Nombre:</strong> @Model.Target.Name</li>
            <li><strong>Estado:</strong> @Model.Target.State</li>
            <li><strong>Fase:</strong> @PhaseHelper.GetPhaseName(Model.Target.Phase)</li>
            <li><strong>Iteracion:</strong> @Model.Target.Iteration</li>
            <li><strong>Tipo req.:</strong> @Model.Target.RequirementTypeName</li>
            <li><strong>CR:</strong> @Model.Target.ChangeRequestCode</li>
            <li><strong>Subida:</strong> @Model.Target.UploadDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</li>
            <li><strong>Version padre:</strong> @(Model.Target.ParentVersionId?.ToString() ?? "-")</li>
        </ul>
    </div>
</div>

<div class="mt-6 rounded-lg bg-white p-5 shadow">
    <h2 class="text-lg font-semibold text-gray-900">Changelog automatico</h2>
    <ul class="mt-3 list-disc space-y-1 pl-5 text-sm text-gray-700">
        @foreach (var item in Model.ChangeLog)
        {
            <li>@item</li>
        }
    </ul>
</div>

<div class="mt-5">
    <a asp-action="Index" asp-route-elementId="@Model.ElementId"
       class="rounded-lg bg-blue-700 px-5 py-2 text-sm font-medium text-white hover:bg-blue-800">
        Volver
    </a>
</div>

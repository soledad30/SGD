@model NotificationBellVM

<div x-data="{ openNotifications: false }" class="relative">
    <button type="button"
            x-on:click="openNotifications = !openNotifications"
            class="relative rounded-full p-1 text-gray-700 hover:bg-gray-100 focus:outline-none"
            title="Notificaciones">
        <i class="fi fi-rr-bell flex h-7 w-7 items-center justify-center text-xl" aria-hidden="true"></i>
        @if (Model.UnreadCount > 0)
        {
            <span class="absolute -top-1 -right-1 inline-flex min-w-5 items-center justify-center rounded-full bg-red-600 px-1 text-xs font-semibold text-white">
                @Model.UnreadCount
            </span>
        }
    </button>

    <div x-show="openNotifications"
         x-on:click.outside="openNotifications = false"
         x-transition
         class="absolute right-1 top-10 z-20 w-[22rem] max-w-[calc(100vw-1.5rem)] overflow-hidden rounded-xl border border-indigo-100 bg-white shadow-xl ring-1 ring-indigo-100 sm:right-0 sm:w-96">
        <div class="border-b border-indigo-100 bg-indigo-50/60 px-4 py-3">
            <p class="text-sm font-semibold text-indigo-900">Notificaciones</p>
            <p class="text-xs text-gray-500">No leidas: @Model.UnreadCount</p>
        </div>
        <div class="max-h-72 overflow-y-auto">
            @if (!Model.Latest.Any())
            {
                <p class="px-4 py-3 text-sm text-gray-500">No tienes notificaciones no leidas.</p>
            }
            else
            {
                @foreach (var item in Model.Latest)
                {
                    <a href="@(string.IsNullOrWhiteSpace(item.Link) ? Url.Action("Index", "Notification") : item.Link)"
                       class="block border-b border-indigo-50 px-4 py-2.5 transition hover:bg-indigo-50/50 @(item.IsRead ? "" : "bg-indigo-50/70")">
                        <p class="text-sm font-semibold text-gray-900 break-words">@item.Title</p>
                        <p class="mt-1 text-xs text-gray-700 break-words">@item.Message</p>
                        <p class="mt-1 text-[11px] text-gray-500">@item.CreatedAt.ToLocalTime().ToString("dd/MM HH:mm")</p>
                    </a>
                }
            }
        </div>
        <div class="px-4 py-2.5">
            <a asp-controller="Notification" asp-action="Index"
               class="inline-flex w-full items-center justify-center rounded-lg bg-indigo-600 px-3 py-2 text-sm font-medium text-white transition hover:bg-indigo-700">
                Ver todas
            </a>
        </div>
    </div>
</div>
